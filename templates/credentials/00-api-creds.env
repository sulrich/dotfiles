# NOTE: this file can be a bit of a hot mess at times.  this should be carefully
# managed in its local instantiation (`~/.credentials/00-api-creds.env`) to
# match with the objectives of the host it's running on.
#
# changes to this file should be carefully merged back into the version
# controlled template with only the 1password references integrated.
#
# if something is no longer applicable, it should be removed.  note that there
# may be some interplay between the contents of this file and various filesystem
# hierarchy specific direnv files.  these should be documented as well.

# stop the rate limits on github for homebrew
# export HOMEBREW_GITHUB_API_TOKEN="{{ op://Private/sulrich-github-homebrew/credential }}"

# ----------------------------------------------------------
# AWS creds (nexthop)
# export AWS_ACCESS_KEY_ID="{{ op://Private/nh-aws-access-key-id/credential }}"
# export AWS_SECRET_ACCESS_KEY="{{ op://Private/nh-aws-secret-access-key/credential }}"

# my personal eos.arista.com api token
# export ANET_API_TOKEN=""

# ----------------------------------------------------------
# misc. AI API keys
# personal anthropic API key
# export ANTHROPIC_API_KEY="{{ op://Private/sulrich-botwerks-claude/credential }}"

# nexthop anthropic API key
# export ANTHROPIC_API_KEY="{{ op://Private/sulrich-nexthop-claude/credential }}"

# nexthop gemini API key
# export GEMINI_API_KEY="{{ op://Private/sulrich-nexthop-gemini-api-key/credential }}"

# personal gemini API key
# export GEMINI_API_KEY="{{ op://Private/sulrichbotwerks-gemini-api-key/credential }}"

# ----------------------------------------------------------
# github CLI tool tokens (also used by other tools)
# nexthop github cli token
# export GH_TOKEN="{{ op://Private/sulrich-nexthop-gh-waffletron-cli/expires }}"
# personal cli token
# export GH_TOKEN="{{ op://Private/sulrich-botwerks-gh-waffletron-cli/expires }}"
# these must be aligned for octo.nvim plugin
export GITHUB_TOKEN=${GH_TOKEN}

# jira token config (nexthop)
export JIRA_AUTH_TYPE="bearer"
# export JIRA_API_TOKEN="{{ op://Private/sulrich-nexthop-jira-cli/credential }}"

# gws tooling setup
# 1. install googleworkplace-cli (aka gws)
# 2. create necessary oauth elements per instructions
# 3. export credentials to run headless per instructions.
# 4. store in this file
export GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE="${HOME}/.credentials/gws-credentials.json"
